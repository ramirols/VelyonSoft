---
import { getCollection } from "astro:content";
import { ArrowUpRight, FolderKanban, Zap, Layout } from "lucide-astro";

const { lang } = Astro.props;

if (!lang) {
  throw new Error("ProyectosGrid: lang prop is required");
}

const projects = (await getCollection("proyectos"))
  .filter((p) => p.data.featured)
  .slice(0, 3);

const t = {
  es: {
    title: "Proyectos",
    subtitle: "Soluciones digitales que impulsan resultados reales.",
    viewAll: "Explorar portafolio",
    viewProject: "Ver detalles",
    impact: "Impacto",
  },
  en: {
    title: "Projects",
    subtitle: "Digital solutions driving real-world results.",
    viewAll: "Explore portfolio",
    viewProject: "View details",
    impact: "Impact",
  },
};

const i18n = lang === "es" ? t.es : t.en;
---

<section id="proyectos" class="bg-white py-12 md:py-20 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <div
      class="flex flex-col md:flex-row md:items-end justify-between mb-10 md:mb-16 gap-6"
    >
      <div class="space-y-4 text-left">
        <div
          class="flex items-center gap-2 text-secondary font-bold tracking-[0.2em] text-[10px] uppercase"
        >
          <FolderKanban size={14} />
          <span>Portafolio</span>
        </div>
        <h2
          class="text-3xl md:text-5xl font-black tracking-tighter text-primary leading-tight"
        >
          {i18n.title}
        </h2>
        <p
          class="text-zinc-500 text-base md:text-lg font-light max-w-md leading-relaxed"
        >
          {i18n.subtitle}
        </p>
      </div>

      <a
        href={`/${lang}/proyectos`}
        class="group inline-flex items-center gap-3 text-sm font-bold text-primary hover:text-secondary transition-colors w-fit"
      >
        {i18n.viewAll}
        <div
          class="w-10 h-10 rounded-full border border-zinc-100 flex items-center justify-center group-hover:border-secondary/30 group-hover:bg-secondary/5 transition-all"
        >
          <ArrowUpRight
            class="w-4 h-4 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
          />
        </div>
      </a>
    </div>

    <div class="grid gap-6 sm:gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project) => (
          <div class="group relative bg-zinc-50/50 rounded-[2rem] md:rounded-[2.5rem] border border-gray-200 p-4 transition-all duration-500 hover:bg-white hover:shadow-[0_30px_60px_-15px_rgba(0,0,0,0.05)] hover:border-secondary">
            <div class="relative aspect-[4/3] overflow-hidden rounded-[1.5rem] md:rounded-[1.8rem] mb-6">
              <img
                src={project.data.cover}
                alt={project.data.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
            </div>

            <div class="px-2 md:px-3 pb-2">
              <h3 class="text-lg md:text-xl font-bold text-primary mb-2 truncate group-hover:text-secondary transition-colors">
                {project.data.title}
              </h3>

              <p class="text-zinc-500 text-sm font-light mb-6 line-clamp-2 leading-relaxed">
                {project.data.description}
              </p>

              <div class="flex items-center gap-3 py-3 px-4 rounded-xl md:rounded-2xl bg-white border border-gray-200 mb-6 md:mb-8 group-hover:border-secondary transition-colors shadow-sm overflow-hidden">
                <div class="text-secondary flex-shrink-0">
                  <Zap size={16} fill="currentColor" />
                </div>
                <p class="text-[11px] md:text-[12px] font-bold text-primary truncate">
                  <span class="text-gray-400 uppercase tracking-wider mr-1 font-medium">
                    {i18n.impact}:
                  </span>
                  {project.data.result}
                </p>
              </div>

              <a
                href={`/${lang}/proyectos/${project.id}`}
                class="flex items-center justify-between text-[10px] md:text-xs font-bold uppercase tracking-widest text-zinc-400 group-hover:text-primary transition-colors"
              >
                {i18n.viewProject}
                <ArrowUpRight class="w-4 h-4 opacity-100 md:opacity-0 -translate-x-2 md:group-hover:opacity-100 md:group-hover:translate-x-0 transition-all" />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
