---
import { getCollection } from "astro:content";
import { ArrowUpRight, Zap } from "lucide-astro";

const { lang } = Astro.props;

if (!lang) {
  throw new Error("ProyectosGrid: lang prop is required");
}

const projects = (await getCollection("proyectos"))
  .filter((p) => p.data.featured)
  .slice(0, 3);

const t = {
  es: {
    eyebrow: "Portafolio",
    title: "Proyectos &",
    titleAccent: "Casos de Éxito",
    subtitle:
      "Soluciones digitales a medida que impulsan el crecimiento de tu marca con resultados medibles.",
    viewAll: "Ver portafolio completo",
    viewProject: "Ver caso de estudio",
    impact: "Resultado clave",
    index: ["01", "02", "03"],
    schemaType: "CreativeWork",
  },
  en: {
    eyebrow: "Portfolio",
    title: "Projects &",
    titleAccent: "Success Stories",
    subtitle:
      "Custom web development and digital solutions engineered to drive measurable growth and brand authority.",
    viewAll: "Explore full portfolio",
    viewProject: "View case study",
    impact: "Key outcome",
    index: ["01", "02", "03"],
    schemaType: "CreativeWork",
  },
};

const i18n = lang === "es" ? t.es : t.en;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: i18n.title + " " + i18n.titleAccent,
  description: i18n.subtitle,
  itemListElement: projects.map((project, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "CreativeWork",
      name: project.data.title,
      description: project.data.description,
      image: project.data.cover,
      url: `/${lang}/proyectos/${project.id}`,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

<section
  id="proyectos"
  aria-label={i18n.title + " " + i18n.titleAccent}
  class="relative py-15 md:py-15 overflow-hidden font-sans"
>
  <div class="pointer-events-none absolute inset-0 z-0" aria-hidden="true">
    <div
      class="absolute -top-48 -right-36 w-[600px] h-[600px] rounded-full opacity-40"
      style="background: radial-gradient(circle, #d4eef5 0%, transparent 70%); filter: blur(90px);"
    >
    </div>
    <div
      class="absolute -bottom-24 -left-24 w-[400px] h-[400px] rounded-full opacity-25"
      style="background: radial-gradient(circle, #cce9f0 0%, transparent 70%); filter: blur(80px);"
    >
    </div>
    <div
      class="absolute inset-0 opacity-[0.4]"
      style="
        background-image: linear-gradient(var(--color-border) 1px, transparent 1px),
                          linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 100%);
      "
    >
    </div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-6">
    <header
      class="mb-16 md:mb-20 opacity-0 animate-fade-up"
      style="animation-delay: 0.05s;"
    >
      <div class="flex items-center gap-3 mb-7" aria-hidden="true">
        <span class="block w-8 h-px bg-secondary"></span>
        <span
          class="text-[0.6rem] font-semibold tracking-[0.28em] uppercase text-secondary"
        >
          {i18n.eyebrow}
        </span>
      </div>

      <div
        class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 lg:gap-16"
      >
        <h2
          class="m-0 shrink-0 text-[clamp(2.6rem,5.5vw,5rem)] leading-[1.05] text-primary font-black"
        >
          <span class="not-italic">{i18n.title}</span>
          <br />
          <em class="not-italic italic text-secondary">{i18n.titleAccent}</em>
        </h2>

        <div class="max-w-xs lg:max-w-sm pb-1 shrink-0">
          <p
            class="text-sm font-light text-muted-foreground leading-relaxed mb-6"
          >
            {i18n.subtitle}
          </p>
          <a
            href={`/${lang}/proyectos`}
            aria-label={i18n.viewAll}
            class="group inline-flex items-center gap-3 text-primary text-[0.78rem] font-medium tracking-wide no-underline transition-colors duration-300 hover:text-secondary"
          >
            <span>{i18n.viewAll}</span>
            <span
              aria-hidden="true"
              class="flex items-center justify-center w-8 h-8 border border-border rounded-full transition-all duration-300 group-hover:bg-secondary group-hover:border-secondary group-hover:text-white group-hover:rotate-45"
            >
              <ArrowUpRight size={15} />
            </span>
          </a>
        </div>
      </div>
    </header>

    <ul
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 items-stretch list-none p-0 m-0"
      role="list"
      aria-label={lang === "es" ? "Proyectos destacados" : "Featured projects"}
    >
      {
        projects.map((project, i) => (
          <li
            class:list={[
              "flex opacity-0 animate-fade-up",
              i === 1 ? "lg:mt-10" : "",
            ]}
            style={`animation-delay: ${0.18 + i * 0.12}s`}
          >
            <article
              class="group flex flex-col w-full"
              itemscope
              itemtype="https://schema.org/CreativeWork"
            >
              <meta itemprop="name" content={project.data.title} />
              <meta itemprop="description" content={project.data.description} />
              <meta itemprop="image" content={project.data.cover} />

              <a
                href={`/${lang}/proyectos/${project.id}`}
                rel="noopener noreferrer"
                itemprop="url"
                aria-label={`${project.data.title} — ${i18n.viewProject}`}
                class="flex flex-col flex-1 no-underline bg-white border border-border rounded-[1.2rem] overflow-hidden transition-all duration-500 hover:-translate-y-1.5 hover:shadow-[0_20px_50px_rgba(30,172,204,0.10)] hover:border-secondary/50"
                style="transition-timing-function: cubic-bezier(0.16,1,0.3,1);"
              >
                <span
                  aria-hidden="true"
                  class="block font-display text-[0.65rem] font-black italic text-secondary/70 tracking-widest pt-5 px-5"
                >
                  {i18n.index[i]}
                </span>

                <div class="relative px-3 pt-2 pb-0">
                  <div class="relative aspect-[4/3] rounded-[0.75rem] overflow-hidden bg-muted">
                    <img
                      src={project.data.cover}
                      alt={`Captura del proyecto ${project.data.title}`}
                      width="600"
                      height="450"
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.05]"
                      style="transition-timing-function: cubic-bezier(0.16,1,0.3,1);"
                      loading="lazy"
                      decoding="async"
                    />
                    <div
                      aria-hidden="true"
                      class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-primary/30 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                    />
                    <span
                      aria-hidden="true"
                      class="absolute top-3 right-3 flex items-center justify-center w-8 h-8 bg-white rounded-full shadow-lg text-primary opacity-0 scale-75 -rotate-45 transition-all duration-300 group-hover:opacity-100 group-hover:scale-100 group-hover:rotate-0"
                    >
                      <ArrowUpRight size={14} />
                    </span>
                  </div>
                </div>

                <div class="flex flex-col flex-1 px-5 pb-5 pt-4">
                  {project.data.tags && project.data.tags.length > 0 && (
                    <div
                      class="flex flex-wrap gap-1.5 mb-3"
                      aria-label="Categorías"
                    >
                      {project.data.tags.slice(0, 2).map((tag) => (
                        <span class="text-[0.57rem] font-semibold tracking-[0.14em] uppercase text-secondary bg-secondary/10 px-2.5 py-0.5 rounded-full">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}

                  <h3 class="text-[1.15rem] font-bold leading-snug text-primary mb-2 transition-colors duration-300 group-hover:text-secondary line-clamp-2">
                    {project.data.title}
                  </h3>

                  <p class="text-[0.82rem] font-light text-muted-foreground leading-relaxed mb-5 line-clamp-3 flex-1">
                    {project.data.description}
                  </p>

                  <div class="flex items-start gap-2.5 bg-secondary/[0.07] border border-secondary/20 rounded-xl px-3.5 py-2.5 mb-4 transition-colors duration-300 group-hover:bg-secondary/[0.12]">
                    <span
                      class="text-secondary shrink-0 mt-0.5"
                      aria-hidden="true"
                    >
                      <Zap size={11} fill="currentColor" />
                    </span>
                    <div class="flex flex-col gap-0.5 min-w-0">
                      <span class="text-[0.55rem] font-semibold tracking-[0.2em] uppercase text-secondary/70">
                        {i18n.impact}
                      </span>
                      <span class="text-[0.77rem] font-medium text-primary leading-snug line-clamp-2">
                        {project.data.result}
                      </span>
                    </div>
                  </div>

                  <div class="flex items-center gap-3 mt-auto">
                    <span class="text-[0.65rem] font-semibold tracking-[0.12em] uppercase text-muted-foreground transition-colors duration-300 group-hover:text-secondary whitespace-nowrap">
                      {i18n.viewProject}
                    </span>
                    <span
                      aria-hidden="true"
                      class="flex-1 h-px bg-border transition-colors duration-300 group-hover:bg-secondary/40"
                    />
                    <span
                      aria-hidden="true"
                      class="text-muted-foreground transition-all duration-300 group-hover:text-secondary group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                    >
                      <ArrowUpRight size={13} />
                    </span>
                  </div>
                </div>
              </a>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fade-up 0.75s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .font-display {
    font-family: "Fraunces Variable", Georgia, serif;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
