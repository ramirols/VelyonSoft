---
import { Check, Info, Sparkles } from "lucide-astro";

interface Props {
    icon: any;
    badge?: string;
    title: string;
    price: {
        original: { pen: string };
        offer?: { pen: string; note?: string };
    };
    features: { text: string }[];
    ctaText: string;
    ctaHref: string;
    highlight?: boolean;
    lang?: "es" | "en";
}

const {
    icon: Icon,
    badge,
    title,
    price,
    features,
    ctaText,
    ctaHref,
    highlight = false,
    lang = "es",
} = Astro.props;

const t = {
    es: {
        important: "Precio base",
        info: "Precio base referencial. El costo final depende de las funcionalidades y personalización solicitadas.",
    },
    en: {
        important: "Starting price",
        info: "Starting price. Final cost depends on specific features and customization requested.",
    },
}[lang];

const displayPrice = price.offer?.pen ?? price.original.pen;
const originalPrice = price.offer ? price.original.pen : null;
---

<article
    class:list={[
        "card group relative flex flex-col w-full transition-all duration-500",
        highlight ? "card--highlight" : "card--default",
    ]}
    itemscope
    itemtype="https://schema.org/Service"
>
    <!-- Glow ring (highlight only) -->
    {highlight && (
        <div
            class="absolute -inset-[1px] rounded-[1.6rem] -z-10 opacity-80"
            style="background: linear-gradient(160deg, var(--color-secondary) 0%, rgba(30,172,204,0.4) 50%, transparent 100%);"
            aria-hidden="true"
        />
    )}

    <div class:list={[
        "relative flex flex-col flex-1 rounded-[1.5rem] overflow-hidden",
        highlight ? "bg-white" : "bg-white border border-border",
    ]}>

        <!-- ✦ Animated corner orb (highlight only) -->
        {highlight && (
            <div class="orb-wrapper absolute top-0 right-0 w-40 h-40 pointer-events-none overflow-hidden rounded-tr-[1.5rem]" aria-hidden="true">
                <!-- Orb 1: slow rotate -->
                <div class="orb orb-1" />
                <!-- Orb 2: counter-rotate, offset -->
                <div class="orb orb-2" />
                <!-- Shimmer streak -->
                <div class="shimmer-streak" />
            </div>
        )}

        <!-- Soft top wash (highlight only) -->
        {highlight && (
            <div
                class="absolute top-0 inset-x-0 h-32 pointer-events-none z-0"
                style="background: linear-gradient(180deg, rgba(30,172,204,0.05) 0%, transparent 100%);"
                aria-hidden="true"
            />
        )}

        <div class="relative z-10 flex flex-col flex-1 p-8">

            <!-- Header row: badge + icon -->
            <div class="flex items-start justify-between mb-8">
                {badge ? (
                    <div class:list={[
                        "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.57rem] font-bold uppercase tracking-[0.18em]",
                        highlight
                            ? "bg-secondary/10 text-secondary border border-secondary/20"
                            : "bg-muted text-muted-foreground border border-border",
                    ]}>
                        {highlight && <Sparkles size={10} aria-hidden="true" />}
                        {badge}
                    </div>
                ) : (
                    <span />
                )}

                <div
                    class:list={[
                        "flex items-center justify-center w-10 h-10 rounded-2xl transition-all duration-300",
                        highlight
                            ? "bg-secondary text-white shadow-lg shadow-secondary/30"
                            : "bg-muted text-primary group-hover:bg-secondary/10 group-hover:text-secondary",
                    ]}
                    aria-hidden="true"
                >
                    <Icon size={19} strokeWidth={1.8} />
                </div>
            </div>

            <!-- Title -->
            <h3
                class="font-display text-[1.35rem] font-bold text-primary mb-1 tracking-tight leading-snug"
                itemprop="name"
            >
                {title}
            </h3>

            <!-- Price -->
            <div class="relative group/tooltip mb-8 mt-3">
                {originalPrice && (
                    <span class="text-xs text-muted-foreground line-through block mb-0.5">
                        {originalPrice}
                    </span>
                )}

                <div class="flex items-end gap-2.5">
                    <span
                        class:list={[
                            "font-display font-black tracking-tighter leading-none",
                            highlight
                                ? "text-[2.6rem] text-secondary"
                                : "text-[2.4rem] text-primary",
                        ]}
                        itemprop="offers"
                        itemscope
                        itemtype="https://schema.org/Offer"
                    >
                        <meta itemprop="price" content={displayPrice} />
                        <meta itemprop="priceCurrency" content="USD" />
                        {displayPrice}
                    </span>

                    <button
                        type="button"
                        aria-label={t.important}
                        class="mb-1.5 text-muted-foreground/40 hover:text-muted-foreground transition-colors duration-200 cursor-help"
                    >
                        <Info size={14} aria-hidden="true" />
                    </button>
                </div>

                {price.offer?.note && (
                    <span class="text-[0.62rem] text-secondary font-semibold uppercase tracking-wider mt-1.5 block">
                        {price.offer.note}
                    </span>
                )}

                <!-- Tooltip -->
                <div
                    role="tooltip"
                    class="absolute bottom-full left-0 mb-3 w-64 p-4 bg-primary text-white rounded-2xl text-[0.7rem] leading-relaxed opacity-0 invisible group-hover/tooltip:opacity-100 group-hover/tooltip:visible transition-all duration-200 z-30 shadow-2xl pointer-events-none"
                >
                    {t.info}
                    <div class="absolute top-full left-5 border-8 border-transparent border-t-primary" aria-hidden="true" />
                </div>
            </div>

            <!-- Divider -->
            <div class:list={["h-px mb-6", highlight ? "bg-secondary/12" : "bg-border"]} aria-hidden="true" />

            <!-- Features -->
            <ul class="space-y-3.5 flex-1 mb-8" itemprop="description">
                {features.map((f) => (
                    <li class="flex items-center gap-3 text-[0.84rem] text-primary/75">
                        <span
                            class:list={[
                                "flex-shrink-0 flex items-center justify-center w-[18px] h-[18px] rounded-full",
                                highlight
                                    ? "bg-secondary text-white"
                                    : "bg-secondary/10 text-secondary",
                            ]}
                            aria-hidden="true"
                        >
                            <Check size={10} strokeWidth={3} />
                        </span>
                        {f.text}
                    </li>
                ))}
            </ul>

            <!-- CTA -->
            <a
                href={ctaHref}
                rel="noopener noreferrer"
                class:list={[
                    "block text-center rounded-2xl py-3.5 text-[0.82rem] font-bold tracking-wide transition-all duration-300 mt-auto",
                    highlight
                        ? "bg-secondary text-white hover:bg-secondary/90 shadow-md shadow-secondary/25"
                        : "border border-primary/12 text-primary hover:bg-primary hover:text-white hover:border-primary",
                ]}
            >
                {ctaText}
            </a>
        </div>
    </div>
</article>

<style>
    .font-display {
        font-family: "Clash Display", "Fraunces Variable", Georgia, serif;
    }

    /* ── Highlight card ───────────────────────────── */
    .card--highlight {
        filter: drop-shadow(0 28px 56px rgba(30, 172, 204, 0.13));
        transform: translateY(-6px);
    }

    /* ── Default card hover ───────────────────────── */
    .card--default:hover {
        transform: translateY(-4px);
    }
    .card--default:hover > div {
        border-color: rgba(30, 172, 204, 0.28);
        box-shadow: 0 20px 48px rgba(30, 172, 204, 0.07);
    }

    /* ── Animated corner orbs ─────────────────────── */
    .orb {
        position: absolute;
        border-radius: 50%;
        /* respects prefers-reduced-motion */
    }

    .orb-1 {
        width: 110px;
        height: 110px;
        top: -30px;
        right: -30px;
        background: radial-gradient(circle at 40% 40%, rgba(30,172,204,0.35) 0%, transparent 70%);
        animation: orb-spin 8s linear infinite;
    }

    .orb-2 {
        width: 70px;
        height: 70px;
        top: 10px;
        right: 10px;
        background: radial-gradient(circle at 60% 60%, rgba(30,172,204,0.2) 0%, transparent 70%);
        animation: orb-spin 5s linear infinite reverse;
    }

    /* Shimmer streak that crosses the corner */
    .shimmer-streak {
        position: absolute;
        top: -10px;
        right: -40px;
        width: 18px;
        height: 100px;
        background: linear-gradient(
            180deg,
            transparent 0%,
            rgba(255,255,255,0.55) 40%,
            rgba(255,255,255,0.7) 50%,
            rgba(255,255,255,0.55) 60%,
            transparent 100%
        );
        border-radius: 999px;
        transform: rotate(-40deg);
        animation: shimmer-move 4s ease-in-out infinite;
    }

    @keyframes orb-spin {
        0%   { transform: rotate(0deg)   scale(1);    opacity: 0.9; }
        25%  { transform: rotate(90deg)  scale(1.08); opacity: 1;   }
        50%  { transform: rotate(180deg) scale(1);    opacity: 0.75;}
        75%  { transform: rotate(270deg) scale(0.95); opacity: 1;   }
        100% { transform: rotate(360deg) scale(1);    opacity: 0.9; }
    }

    @keyframes shimmer-move {
        0%   { opacity: 0;   transform: rotate(-40deg) translateY(0px);   }
        20%  { opacity: 1;   transform: rotate(-40deg) translateY(10px);  }
        60%  { opacity: 0.6; transform: rotate(-40deg) translateY(30px);  }
        100% { opacity: 0;   transform: rotate(-40deg) translateY(60px);  }
    }

    /* Respect reduced-motion preferences */
    @media (prefers-reduced-motion: reduce) {
        .orb-1, .orb-2, .shimmer-streak {
            animation: none;
        }
    }
</style>