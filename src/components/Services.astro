---
import { Laptop, Code, Boxes, Phone, LayoutGrid } from "lucide-astro";
import ServiceCard from "./ServiceCard.astro";
import { servicesData } from "../data/services";

interface Props {
    lang?: "es" | "en";
    onlyFeatured?: boolean;
}

const { lang = "es", onlyFeatured = false } = Astro.props;

const t = {
    es: {
        badge: "Soluciones",
        sectionTitle: "Soluciones digitales",
        sectionTitleAccent: "para negocios",
        sectionDesc:
            "Desarrollamos páginas web, sistemas y automatizaciones para empresas que buscan vender más, mejorar su atención y optimizar procesos.",
        note: "Nota: Todos los precios son referenciales. El costo final depende de las funcionalidades y personalización solicitadas.",
        badges: {
            starter: "Ideal para emprendedores",
            popular: "Más vendido",
            business: "Empresas",
        },
        prices: {
            starter: "$199 USD",
            popular: "$499 USD",
            premium: "Desde $999",
        },
        features: {
            responsive: "Diseño moderno y responsive",
            seoBasic: "SEO básico optimizado",
            seoAdvanced: "SEO avanzado",
            speed: "Velocidad optimizada",
            contact: "Formulario de contacto",
            custom: "Desarrollo personalizado",
            automation: "Automatizaciones",
            scale: "Escalabilidad",
            support: "Soporte prioritario",
            android: "Aplicaciones Android",
            ios: "Aplicaciones iOS",
            marketing: "Estrategias de marketing digital",
            office: "Soporte en Ofimática",
            itSupport: "Soporte técnico general",
            wordpress: "Desarrollo de sitios web con WordPress",
        },
        ctaStart: "Comenzar ahora",
        ctaAll: "Ver todos los servicios",
    },
    en: {
        badge: "Solutions",
        sectionTitle: "Digital solutions",
        sectionTitleAccent: "for businesses",
        sectionDesc:
            "We develop websites, systems and automations for companies looking to sell more, improve their customer service and optimize processes.",
        note: "Note: All prices are referential. The final cost depends on the functionalities and customization requested.",
        badges: {
            starter: "Perfect for startups",
            popular: "Best seller",
            business: "Businesses",
        },
        prices: {
            starter: "$199 USD",
            popular: "$499 USD",
            premium: "From $999",
        },
        features: {
            responsive: "Modern & responsive design",
            seoBasic: "Basic SEO optimization",
            seoAdvanced: "Advanced SEO",
            speed: "Optimized performance",
            contact: "Contact form",
            custom: "Custom development",
            automation: "Automations",
            scale: "Scalability",
            support: "Priority support",
            android: "Android applications",
            ios: "iOS applications",
            marketing: "Digital marketing strategies",
            office: "Office support",
            itSupport: "IT support",
            wordpress: "WordPress development",
        },
        ctaStart: "Get started",
        ctaAll: "View all services",
    },
}[lang];

const plans = onlyFeatured
    ? servicesData[lang].filter((p) => p.featured)
    : servicesData[lang];

const serviceIcons = {
    laptop: Laptop,
    code: Code,
    boxes: Boxes,
    phone: Phone,
};

// JSON-LD SEO
const schemaData = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name:
        lang === "es"
            ? "Planes y precios de servicios"
            : "Service plans & pricing",
    description: t.sectionDesc,
    itemListElement: plans.map((plan, i) => ({
        "@type": "ListItem",
        position: i + 1,
        item: {
            "@type": "Service",
            name: plan.nombre,
            offers: {
                "@type": "Offer",
                price: plan.price?.original?.pen ?? "",
                priceCurrency: "USD",
            },
        },
    })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

<section
    id="planes-precios"
    aria-label={lang === "es"
        ? "Planes y precios de servicios"
        : "Service plans and pricing"}
    class="relative py-15 md:py-15 overflow-hidden"
>
    <div class="pointer-events-none absolute inset-0 z-0" aria-hidden="true">
        <div
            class="absolute -top-40 -left-40 w-[500px] h-[500px] rounded-full opacity-30"
            style="background: radial-gradient(circle, #d4eef5 0%, transparent 70%); filter: blur(80px);"
        >
        </div>
        <div
            class="absolute -bottom-32 -right-32 w-[450px] h-[450px] rounded-full opacity-20"
            style="background: radial-gradient(circle, #cce9f0 0%, transparent 70%); filter: blur(80px);"
        >
        </div>
        <div
            class="absolute inset-0 opacity-[0.35]"
            style="
                background-image: linear-gradient(var(--color-border) 1px, transparent 1px),
                                  linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
                background-size: 60px 60px;
                mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 100%);
            "
        >
        </div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-6">
        <header
            class="text-center mb-16 md:mb-20 opacity-0 animate-fade-up"
            style="animation-delay: 0.05s;"
        >
            <div
                class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full bg-secondary/10 border border-secondary/20 text-secondary mb-7"
            >
                <LayoutGrid size={13} />
                <span
                    class="text-[0.6rem] font-bold uppercase tracking-[0.25em]"
                >
                    {t.badge}
                </span>
            </div>

            <h2
                class="font-display text-[clamp(2.2rem,5vw,4rem)] font-bold leading-[1.05] text-primary mb-5 tracking-tight"
            >
                {t.sectionTitle}
                <br />
                <em class="not-italic italic text-secondary"
                    >{t.sectionTitleAccent}</em
                >
            </h2>

            <p
                class="text-muted-foreground max-w-xl mx-auto text-base font-light leading-relaxed"
            >
                {t.sectionDesc}
            </p>

            <p
                class="text-primary max-w-xl mx-auto text-base font-bold leading-relaxed"
            >
                {t.note}
            </p>
        </header>

        <ul
            class="grid gap-6 md:grid-cols-3 items-stretch list-none p-0 m-0"
            role="list"
            aria-label={lang === "es" ? "Planes de servicio" : "Service plans"}
        >
            {
                plans.map((plan, i) => (
                    <li
                        class="flex opacity-0 animate-fade-up"
                        style={`animation-delay: ${0.15 + i * 0.1}s`}
                    >
                        <ServiceCard
                            lang={lang}
                            icon={serviceIcons[plan.icon]}
                            badge={
                                plan.badgeKey
                                    ? t.badges[plan.badgeKey]
                                    : undefined
                            }
                            title={plan.nombre}
                            highlight={plan.highlight}
                            features={plan.features.map((f) => ({
                                icon: f.icon,
                                text: (t.features as Record<string, string>)[
                                    f.textKey
                                ],
                            }))}
                            ctaText={
                                plan.cta.type === "contact"
                                    ? t.ctaStart
                                    : t.ctaAll
                            }
                            ctaHref={
                                plan.cta.type === "contact"
                                    ? `/${lang}#contacto`
                                    : `/${lang}/servicios`
                            }
                        />
                    </li>
                ))
            }
        </ul>
    </div>
</section>

<style>
    @keyframes fade-up {
        from {
            opacity: 0;
            transform: translateY(24px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-up {
        animation: fade-up 0.75s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .font-display {
        font-family: "Clash Display", "Fraunces Variable", Georgia, serif;
    }
</style>
