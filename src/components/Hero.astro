---
import { CheckCircle } from "lucide-astro";

type Lang = "es" | "en";

interface Props {
    lang?: Lang;
}

const { lang = "es" } = Astro.props;

const t = {
    es: {
        badge: "Empresa de desarrollo de software en Perú",
        title: "Desarrollo de software a medida para empresas en Perú",
        subtitle:
            "Creamos sistemas web, automatizaciones y soluciones digitales para empresas que buscan optimizar procesos, ahorrar tiempo y crecer con tecnología.",
        bullets: [
            "Software a medida según tus procesos",
            "Sistemas web para operaciones y ventas",
            "Automatización de tareas y atención",
            "Implementación para empresas en Perú",
        ],
        ctaPrimary: "Solicitar propuesta",
        ctaSecondary: "Ver proyectos",
        trust: "Soluciones para empresas, negocios y organizaciones que quieren digitalizarse",
    },
    en: {
        badge: "Software development company in Peru",
        title: "Custom software development for businesses in Peru",
        subtitle:
            "We build web systems, automations and digital solutions for companies that want to optimize operations, save time and grow with technology.",
        bullets: [
            "Custom software based on your processes",
            "Web systems for operations and sales",
            "Task and customer service automation",
            "Implementation for businesses in Peru",
        ],
        ctaPrimary: "Request a proposal",
        ctaSecondary: "View projects",
        trust: "Solutions for companies and organizations looking to digitize operations",
    },
}[lang];

const heroSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name:
        lang === "es"
            ? "Desarrollo de software a medida para empresas en Perú"
            : "Custom software development for businesses in Peru",
    provider: {
        "@type": "Organization",
        name: "VelyonSoft",
        url: "https://www.velyonsoft.com",
    },
    areaServed: {
        "@type": "Country",
        name: "Peru",
    },
    serviceType:
        lang === "es"
            ? "Desarrollo de software a medida, sistemas web y automatización"
            : "Custom software development, web systems and automation",
};
---

<script type="application/ld+json" set:html={JSON.stringify(heroSchema)} />

<section
    id="inicio"
    class="relative overflow-hidden bg-zinc-950 text-white"
    aria-label={lang === "es" ? "Hero principal" : "Main hero"}
>
    <div
        class="absolute inset-0 bg-cover bg-top"
        style="background-image: url('/images/slider-font.webp');"
    >
    </div>
    <div class="absolute inset-0 bg-black/50"></div>

    <div
        class="relative z-10 max-w-6xl mx-auto px-4 pt-32 pb-16 sm:px-6 md:pt-40 md:pb-28"
    >
        <div class="max-w-3xl">
            <div
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-8"
            >
                <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"
                ></span>
                <span
                    class="text-[11px] md:text-xs uppercase tracking-[0.18em] font-semibold text-white/75"
                >
                    {t.badge}
                </span>
            </div>

            <h1
                class="text-[2.35rem] sm:text-5xl md:text-6xl font-black tracking-tight leading-[1.05] mb-6"
            >
                {t.title}
            </h1>

            <p
                class="text-base md:text-xl text-white/80 leading-relaxed max-w-2xl mb-8"
            >
                {t.subtitle}
            </p>

            <ul class="grid sm:grid-cols-2 gap-3 mb-10 list-none p-0">
                {
                    t.bullets.map((item) => (
                        <li class="flex items-start gap-3 text-sm md:text-base text-white/90">
                            <CheckCircle class="w-5 h-5 text-cyan-400 mt-1 flex-shrink-0" />
                            <span>{item}</span>
                        </li>
                    ))
                }
            </ul>

            <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
                <a
                    href={`/${lang}#contacto`}
                    class="inline-flex items-center justify-center rounded-2xl bg-cyan-400 px-6 py-3.5 font-bold text-black transition hover:scale-[1.02] hover:bg-cyan-300 sm:px-7 sm:py-4"
                >
                    {t.ctaPrimary}
                </a>
                <a
                    href={`/${lang}/proyectos`}
                    class="inline-flex items-center justify-center rounded-2xl border border-white/15 px-6 py-3.5 font-semibold text-white/90 transition hover:bg-white/5 sm:px-7 sm:py-4"
                >
                    {t.ctaSecondary}
                </a>
            </div>

            <p class="mt-8 text-sm text-white/60">{t.trust}</p>
        </div>
    </div>
</section>
