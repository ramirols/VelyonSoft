---
import {
    User,
    Mail,
    MessageSquare,
    Send,
    ShieldCheck,
    Zap,
} from "lucide-astro";

type Lang = "es" | "en";
const { lang = "es" } = Astro.props as { lang?: Lang };

const i18n = {
    es: {
        badge: "Contacto",
        title: "¿Tienes un proyecto en mente?",
        subtitle:
            "Completa el formulario y evaluaremos tu propuesta para darte una cotización ajustada a tus objetivos.",
        nameLabel: "Nombre completo",
        namePlaceholder: "Ej. Juan Pérez",
        emailLabel: "Correo institucional o personal",
        emailPlaceholder: "correo@empresa.com",
        messageLabel: "Detalles del proyecto",
        messagePlaceholder:
            "Cuéntanos sobre las funcionalidades, el alcance y tu presupuesto estimado...",
        hint: "Cuantos más detalles nos des, más precisa será nuestra propuesta 🚀",
        button: "Enviar propuesta",
        trust: "Información protegida por acuerdos de confidencialidad.",
        whatsappIntro: "Hola 👋, soy",
        errors: {
            name: "El nombre es requerido (mín. 3 caracteres)",
            email: "Introduce un correo válido",
            message: "Por favor, cuéntanos un poco más (mín. 10 caracteres)",
        },
    },
    en: {
        badge: "Contact",
        title: "Have a project in mind?",
        subtitle:
            "Fill out the form and we will evaluate your proposal to give you a quote tailored to your goals.",
        nameLabel: "Full name",
        namePlaceholder: "e.g. John Doe",
        emailLabel: "Business or personal email",
        emailPlaceholder: "email@company.com",
        messageLabel: "Project details",
        messagePlaceholder:
            "Tell us about the features, scope, and your estimated budget...",
        hint: "The more details you share, the more accurate our proposal will be 🚀",
        button: "Send proposal",
        trust: "Information protected by non-disclosure agreements.",
        whatsappIntro: "Hi 👋, I'm",
        errors: {
            name: "Name is required (min. 3 characters)",
            email: "Enter a valid email address",
            message: "Please tell us a bit more (min. 10 characters)",
        },
    },
};

const t = i18n[lang];
---

<section id="contacto" class="relative max-w-4xl mx-auto px-4 py-16 sm:px-6 md:py-20 lg:py-24">
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-30 pointer-events-none"
    >
        <div
            class="absolute top-20 left-10 w-72 h-72 bg-secondary/20 rounded-full blur-[120px]"
        >
        </div>
        <div
            class="absolute bottom-20 right-10 w-72 h-72 bg-primary/10 rounded-full blur-[120px]"
        >
        </div>
    </div>

    <header class="text-center mb-12 md:mb-16">
        <div class="flex items-center justify-center gap-2 mb-4">
            <span class="w-8 h-[1px] bg-secondary"></span>
            <span
                class="text-[10px] font-bold tracking-[0.3em] text-secondary uppercase"
                >{t.badge}</span
            >
            <span class="w-8 h-[1px] bg-secondary"></span>
        </div>
        <h2
            class="text-[2rem] md:text-5xl font-black text-primary tracking-tighter mb-6"
        >
            {t.title}
        </h2>
        <p class="text-muted-foreground max-w-2xl mx-auto text-base md:text-lg leading-relaxed">
            {t.subtitle}
        </p>
    </header>

    <div class="grid md:grid-cols-1 relative sm:px-4">
        <div
            class="absolute -top-10 -right-4 md:-top-20 md:-right-10 w-40 h-40 md:w-80 md:h-80 bg-secondary/50 rounded-full blur-3xl -z-10 pointer-events-none"
        >
        </div>

        <div
            class="absolute -bottom-10 -left-4 md:-bottom-20 md:-left-10 w-32 h-32 md:w-64 md:h-64 bg-secondary/60 rounded-full blur-2xl md:blur-3xl -z-10 pointer-events-none"
        >
        </div>

        <form
            id="contactForm"
            novalidate
            class="relative overflow-hidden bg-card border border-border p-5 sm:p-8 md:p-12 rounded-[1.75rem] md:rounded-[2.5rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.05)] transition-all duration-500 hover:shadow-[0_30px_60px_-10px_rgba(0,0,0,0.08)] group/form"
        >
            <div class="relative z-10 grid gap-5 mb-6 md:grid-cols-2 md:gap-8">
                <div class="space-y-2.5">
                    <label
                        for="name"
                        class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.1em] text-primary/80 ml-1"
                    >
                        <User size={14} class="text-secondary" />
                        {t.nameLabel}
                    </label>
                    <input
                        id="name"
                        name="name"
                        type="text"
                        maxlength="50"
                        placeholder={t.namePlaceholder}
                        class="w-full rounded-2xl border border-input bg-background/60 px-5 py-4 text-foreground transition-all duration-300 outline-none placeholder:text-muted-foreground focus:bg-background focus:border-secondary focus:ring-secondary/5"
                    />
                    <span
                        id="nameError"
                        class="text-[12px] text-red-500 font-semibold ml-2 hidden"
                    ></span>
                </div>

                <div class="space-y-2.5">
                    <label
                        for="email"
                        class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.1em] text-primary/80 ml-1"
                    >
                        <Mail size={14} class="text-secondary" />
                        {t.emailLabel}
                    </label>
                    <input
                        id="email"
                        name="email"
                        maxlength="100"
                        type="email"
                        placeholder={t.emailPlaceholder}
                        class="w-full rounded-2xl border border-input bg-background/60 px-5 py-4 text-foreground transition-all duration-300 outline-none placeholder:text-muted-foreground focus:bg-background focus:border-secondary focus:ring-secondary/5"
                    />
                    <span
                        id="emailError"
                        class="text-[12px] text-red-500 font-semibold ml-2 hidden"
                    ></span>
                </div>
            </div>

            <div class="space-y-2.5 mb-8">
                <label
                    for="message"
                    class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.1em] text-primary/80 ml-1"
                >
                    <MessageSquare size={14} class="text-secondary" />
                    {t.messageLabel}
                </label>
                <textarea
                    id="message"
                    name="message"
                    rows="6"
                    maxlength="8000"
                    placeholder={t.messagePlaceholder}
                    class="w-full rounded-2xl border border-input bg-background/60 px-5 py-4 text-foreground transition-all duration-300 outline-none placeholder:text-muted-foreground focus:bg-background focus:border-secondary focus:ring-secondary/5 resize-none"
                ></textarea>
                <span
                    id="messageError"
                    class="text-[12px] text-red-500 font-semibold ml-2 hidden"
                ></span>

                <div class="flex items-start gap-2 mt-4 px-1">
                    <div class="bg-secondary/10 p-1 rounded-md">
                        <Zap size={12} class="text-secondary" />
                    </div>
                    <p class="text-[13px] text-muted-foreground italic leading-tight">
                        {t.hint}
                    </p>
                </div>
            </div>

            <button
                type="submit"
                class="group relative w-full cursor-pointer flex items-center justify-center gap-3 overflow-hidden rounded-2xl bg-primary py-5 font-bold text-primary-foreground transition-all duration-300 hover:bg-secondary hover:text-secondary-foreground active:scale-[0.98] shadow-xl shadow-primary/20"
            >
                <div
                    class="absolute inset-0 w-1/2 h-full bg-white/10 skew-x-[-25deg] -translate-x-full group-hover:animate-[shimmer_0.75s_infinite]"
                >
                </div>

                <span class="relative z-10 tracking-wide">{t.button}</span>
                <Send
                    size={18}
                    class="relative z-10 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform duration-300"
                />
            </button>

            <div
                class="mt-8 flex items-center justify-center gap-4 py-4 border-t border-border"
            >
                <div
                    class="flex flex-wrap items-center justify-center gap-2.5 text-center text-[11px] sm:text-[12px] text-foreground font-bold uppercase tracking-widest"
                >
                    <div class="bg-green-500/10 p-1 rounded-full">
                        <ShieldCheck size={14} class="text-green-600" />
                    </div>
                    {t.trust}
                </div>
            </div>
        </form>
    </div>
</section>

<script
    is:inline
    define:vars={{ whatsappIntro: t.whatsappIntro, errorMsgs: t.errors }}
>
    const initContactForm = () => {
        const form = document.getElementById("contactForm");
        if (!form || form.dataset.bound === "true") return;

        form.dataset.bound = "true";

        const inputs = {
            name: document.getElementById("name"),
            email: document.getElementById("email"),
            message: document.getElementById("message"),
        };

        const errors = {
            name: document.getElementById("nameError"),
            email: document.getElementById("emailError"),
            message: document.getElementById("messageError"),
        };

        const validateEmail = (email) => {
            return String(email)
                .toLowerCase()
                .match(
                    /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/,
                );
        };

        form.addEventListener("submit", (e) => {
            e.preventDefault();
            let isValid = true;

            // Limpiar errores previos
            Object.values(errors).forEach((el) => el.classList.add("hidden"));
            Object.values(inputs).forEach((el) =>
                el.classList.remove("border-red-400", "ring-red-100"),
            );

            // Validación Nombre
            if (inputs.name.value.trim().length < 3) {
                errors.name.textContent = errorMsgs.name;
                errors.name.classList.remove("hidden");
                inputs.name.classList.add("border-red-400", "ring-red-100");
                isValid = false;
            }

            // Validación Email
            if (!validateEmail(inputs.email.value.trim())) {
                errors.email.textContent = errorMsgs.email;
                errors.email.classList.remove("hidden");
                inputs.email.classList.add("border-red-400", "ring-red-100");
                isValid = false;
            }

            // Validación Mensaje
            if (inputs.message.value.trim().length < 10) {
                errors.message.textContent = errorMsgs.message;
                errors.message.classList.remove("hidden");
                inputs.message.classList.add("border-red-400", "ring-red-100");
                isValid = false;
            }

            if (isValid) {
                const whatsappMessage = `${whatsappIntro} *${inputs.name.value.trim()}* 🚀\n\n📧 *Email:* ${inputs.email.value.trim()}\n\n📝 *Proyecto:* \n${inputs.message.value.trim()}`;
                const url = `https://wa.me/51997676432?text=${encodeURIComponent(whatsappMessage)}`;
                window.open(url, "_blank");
            }
        });

        Object.keys(inputs).forEach((key) => {
            inputs[key].addEventListener("input", () => {
                errors[key].classList.add("hidden");
                inputs[key].classList.remove("border-red-400", "ring-red-100");
            });
        });
    };

    initContactForm();
    document.addEventListener("astro:page-load", initContactForm);
</script>
