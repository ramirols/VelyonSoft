---
import {
    User,
    Mail,
    MessageSquare,
    Send,
    ShieldCheck,
    Zap,
} from "lucide-astro";

type Lang = "es" | "en";
const { lang = "es" } = Astro.props as { lang?: Lang };

const i18n = {
    es: {
        badge: "Contacto",
        title: "¿Tienes un proyecto en mente?",
        subtitle:
            "Completa el formulario y evaluaremos tu propuesta para darte una cotización ajustada a tus objetivos.",
        nameLabel: "Nombre completo",
        namePlaceholder: "Ej. Juan Pérez",
        emailLabel: "Correo institucional o personal",
        emailPlaceholder: "correo@empresa.com",
        messageLabel: "Detalles del proyecto",
        messagePlaceholder:
            "Cuéntanos sobre las funcionalidades, el alcance y tu presupuesto estimado...",
        hint: "Cuantos más detalles nos des, más precisa será nuestra propuesta 🚀",
        button: "Enviar propuesta",
        trust: "Información protegida por acuerdos de confidencialidad.",
        whatsappIntro: "Hola 👋, soy",
    },
    en: {
        badge: "Contact",
        title: "Have a project in mind?",
        subtitle:
            "Fill out the form and we will evaluate your proposal to give you a quote tailored to your goals.",
        nameLabel: "Full name",
        namePlaceholder: "e.g. John Doe",
        emailLabel: "Business or personal email",
        emailPlaceholder: "email@company.com",
        messageLabel: "Project details",
        messagePlaceholder:
            "Tell us about the features, scope, and your estimated budget...",
        hint: "The more details you share, the more accurate our proposal will be 🚀",
        button: "Send proposal",
        trust: "Information protected by non-disclosure agreements.",
        whatsappIntro: "Hi 👋, I'm",
    },
};

const t = i18n[lang];
---

<section id="contacto" class="relative max-w-4xl mx-auto px-6 py-15">
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-30 pointer-events-none"
    >
        <div
            class="absolute top-20 left-10 w-72 h-72 bg-secondary/10 rounded-full blur-[120px]"
        >
        </div>
    </div>

    <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-2 mb-4">
            <span class="w-8 h-[1px] bg-secondary"></span>
            <span
                class="text-[10px] font-bold tracking-[0.3em] text-secondary uppercase"
            >
                {t.badge}
            </span>
            <span class="w-8 h-[1px] bg-secondary"></span>
        </div>
        <h2
            class="text-4xl md:text-5xl font-black text-primary tracking-tighter mb-6"
        >
            {t.title}
        </h2>
        <p class="text-gray-500 max-w-2xl mx-auto text-lg leading-relaxed">
            {t.subtitle}
        </p>
    </header>

    <div class="grid md:grid-cols-1 gap-12">
        <form
            id="contactForm"
            class="relative bg-white border border-gray-300 p-8 md:p-12 rounded-[2.5rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.05)] transition-all duration-500 hover:shadow-[0_30px_60px_-15px_rgba(30,172,204,0.1)]"
        >
            <div class="grid md:grid-cols-2 gap-8 mb-8">
                <div class="space-y-2">
                    <label
                        for="name"
                        class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-wider text-primary/60 ml-1"
                    >
                        <User size={14} class="text-secondary" />
                        {t.nameLabel}
                    </label>
                    <input
                        id="name"
                        name="name"
                        type="text"
                        required
                        maxlength="50"
                        placeholder={t.namePlaceholder}
                        class="w-full rounded-2xl border border-gray-300 px-5 py-4 text-primary transition-all outline-none"
                    />
                </div>

                <div class="space-y-2">
                    <label
                        for="email"
                        class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-wider text-primary/60 ml-1"
                    >
                        <Mail size={14} class="text-secondary" />
                        {t.emailLabel}
                    </label>
                    <input
                        id="email"
                        name="email"
                        type="email"
                        required
                        maxlength="30"
                        placeholder={t.emailPlaceholder}
                        class="w-full rounded-2xl border border-gray-300 px-5 py-4 text-primary transition-all outline-none"
                    />
                </div>
            </div>

            <div class="space-y-2 mb-8">
                <label
                    for="message"
                    class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-wider text-primary/60 ml-1"
                >
                    <MessageSquare size={14} class="text-secondary" />
                    {t.messageLabel}
                </label>
                <textarea
                    id="message"
                    name="message"
                    rows="6"
                    required
                    maxlength="3000"
                    placeholder={t.messagePlaceholder}
                    class="w-full rounded-2xl border border-gray-300 px-5 py-4 text-primary transition-all outline-none resize-none"
                ></textarea>
                <div class="flex items-start gap-2 mt-3 px-1">
                    <Zap size={14} class="text-secondary mt-0.5" />
                    <p class="text-xs text-gray-400 italic">
                        {t.hint}
                    </p>
                </div>
            </div>

            <button
                type="submit"
                class="group relative w-full cursor-pointer flex items-center justify-center gap-3 overflow-hidden rounded-2xl bg-primary py-5 font-bold text-white transition-all hover:bg-accent active:scale-[0.98] shadow-xl shadow-primary/10"
            >
                <span class="relative z-10">{t.button}</span>
                <Send
                    size={18}
                    class="relative z-10 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"
                />
            </button>

            <div
                class="mt-8 flex items-center justify-center gap-4 py-4 border-t border-gray-50"
            >
                <div
                    class="flex items-center gap-2 text-[10px] text-gray-400 font-medium"
                >
                    <ShieldCheck size={14} class="text-green-500" />
                    {t.trust}
                </div>
            </div>
        </form>
    </div>
</section>

<script is:inline define:vars={{ whatsappIntro: t.whatsappIntro }}>
    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("contactForm");
        if (!form) return;

        form.addEventListener("submit", (e) => {
            e.preventDefault();
            const data = new FormData(form);

            const name = data.get("name");
            const email = data.get("email");
            const message = data.get("message");

            const whatsappMessage = `${whatsappIntro} *${name}* 🚀\n\n📧 *Email:* ${email}\n\n📝 *Proyecto:* \n${message}`;

            const url = `https://wa.me/51997676432?text=${encodeURIComponent(whatsappMessage)}`;
            window.open(url, "_blank");
        });
    });
</script>
