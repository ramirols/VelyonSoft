---
import Layout from "./Layout.astro";
import Header from "../components/Header.jsx";
import Footer from "../components/Footer.astro";
import { AstroSEO } from "astro-seo-plugin";

import { FloatingBuilderCTA } from "@/components/FloatingBuilderCTA";

const {
    lang = "es",
    title = "VelyonSoft | Desarrollo Web Profesional",
    description = "Desarrollo de páginas web modernas, rápidas y optimizadas para negocios.",
    image = "/og-default.jpg",
    type = "website",
} = Astro.props;

const canonical = Astro.url.href;

const isConstructor = Astro.url.pathname.includes("/constructor");
---

<Layout lang={lang}>
    <AstroSEO
        title={title}
        description={description}
        canonical={canonical}
        openGraph={{
            type,
            locale: lang === "es" ? "es_ES" : "en_US",
            url: canonical,
            siteName: "VelyonSoft",
            images: [
                {
                    url: `https://VelyonSoft.vercel.app${image}`,
                    width: 1200,
                    height: 630,
                    alt: title,
                },
            ],
        }}
        twitter={{
            card: "summary_large_image",
            site: "@VelyonSoft",
        }}
        jsonLd={{
            "@context": "https://schema.org",
            "@type": type === "article" ? "Article" : "Organization",
            name: title,
            url: canonical,
        }}
    />

    {/* Solo mostramos el Header si NO es el constructor */}
    {!isConstructor && <Header client:load lang={lang} />}

    <main
        class={isConstructor
            ? ""
            : "min-h-screen bg-white text-gray-900 font-inter"}
    >
        <slot />
    </main>

    {/* El botón flotante y el footer también se ocultan en el constructor */}
    {
        !isConstructor && (
            <>
                <FloatingBuilderCTA client:idle lang={lang} />
                <Footer lang={lang} />
            </>
        )
    }
</Layout>