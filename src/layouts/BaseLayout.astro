---
import Layout from "./Layout.astro";
import Header from "../components/Header.jsx";
import Footer from "../components/Footer.astro";
import { AstroSEO } from "astro-seo-plugin";
import WhatsAppWidget from "@/components/WhatsAppWidget";

const {
    lang = "es",
    title = "VelyonSoft | Desarrollo de Software y Páginas Web",
    description = "Desarrollo de software a medida, páginas web profesionales, aplicaciones móviles y estrategias SEO para empresas que buscan crecer, vender más y posicionarse en Google.",
    image = "/og-default.jpg",
    type = "website",
} = Astro.props;

const site = "https://velyonsoft.vercel.app";
const canonical = `${site}/${lang}${Astro.url.pathname.replace(/^\/(es|en)/, "")}`;
---

<Layout lang={lang}>
    <AstroSEO
        title={title}
        description={description}
        canonical={canonical}
        openGraph={{
            type,
            locale: lang === "es" ? "es_ES" : "en_US",
            url: canonical,
            siteName: "VelyonSoft",
            title,
            description,
            images: [
                {
                    url: `https://velyonsoft.vercel.app${image}`,
                    width: 1200,
                    height: 630,
                    alt: "VelyonSoft - Desarrollo de Software y Páginas Web",
                },
            ],
        }}
        twitter={{
            card: "summary_large_image",
            site: "@VelyonSoft",
            creator: "@VelyonSoft",
            title,
            description,
            image: `https://velyonsoft.vercel.app${image}`,
        }}
        jsonLd={{
            "@context": "https://schema.org",
            "@type": "Organization",
            name: "VelyonSoft",
            url: "https://velyonsoft.vercel.app",
            logo: "https://velyonsoft.vercel.app/logo.png",
            description: description,
            foundingDate: "2024",
            contactPoint: [
                {
                    "@type": "ContactPoint",
                    contactType: "sales",
                    availableLanguage: ["Spanish", "English"],
                },
            ],
            sameAs: [
                "https://facebook.com/velyonsoft",
                "https://instagram.com/velyonsoft",
                "https://linkedin.com/company/velyonsoft",
                "https://twitter.com/velyonsoft",
            ],
        }}
    />

    <Header client:load lang={lang} />

    <main>
        <slot />
    </main>

    <Footer lang={lang} />
    <WhatsAppWidget client:load />
</Layout>
