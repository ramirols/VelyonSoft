---
import BaseLayout from "./BaseLayout.astro";
import { ArrowRight, ChevronLeft } from "lucide-astro";
const { frontmatter } = Astro.props;
type Lang = "es" | "en";
const lang: Lang = Astro.params.lang === "en" ? "en" : "es";
const readingTime = Math.ceil(frontmatter.words / 200);

const blogHref = `/${lang}/blog`;

const viewAllText =
  lang === "en" ? "View all posts" : "Ver todas las publicaciones";

const backText = lang === "en" ? "Blog" : "Blog";
---

<BaseLayout
  title={`${frontmatter.title} | VelyonSoft`}
  description={frontmatter.description}
  image={frontmatter.cover}
  type="article"
  lang={lang}
>
  <header
    class="relative h-[60vh] min-h-[400px] flex items-end"
    id={frontmatter.cover ? "blog-hero" : undefined}
  >
    {
      frontmatter.cover && (
        <img
          src={frontmatter.cover}
          alt={frontmatter.title}
          class="absolute inset-0 w-full h-full object-cover"
        />
      )
    }
    <div
      class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"
    >
    </div>

    <div class="relative max-w-4xl mx-auto px-6 pb-16 w-full text-white">
      <h1
        class="text-4xl md:text-6xl font-extrabold tracking-tight leading-tight"
      >
        {frontmatter.title}
      </h1>
      <div class="flex flex-wrap gap-4 text-sm mt-6 text-white/80 items-center">
        <span class="bg-white/20 px-3 py-1 rounded-full backdrop-blur-md">
          {
            new Date(frontmatter.date).toLocaleDateString(
              lang === "en" ? "en-US" : "es-PE",
              {
                day: "numeric",
                month: "long",
                year: "numeric",
              },
            )
          }
        </span>
        <span>•</span>
        <span class="font-medium text-white">{frontmatter.author}</span>
        <span>•</span>
        <span>{readingTime} {lang === "en" ? "min read" : "min lectura"}</span>
      </div>
    </div>
  </header>

  <main class="bg-background">
    <nav class="max-w-3xl mx-auto px-6 pt-10">
      <div class="flex items-center gap-2 text-muted-foreground text-sm">
        <a
          href={blogHref}
          class="flex items-center gap-1 hover:text-primary transition-colors font-medium"
        >
          <ChevronLeft class="h-[18px] w-[18px]" stroke-width={2.5} />
          {backText}
        </a>
        <span class="text-border">/</span>
        <span class="truncate text-muted-foreground">{frontmatter.title}</span>
      </div>
    </nav>

    <article
      class="max-w-3xl mx-auto px-6 py-10
      prose prose-neutral dark:prose-invert prose-lg
      prose-headings:font-bold
      prose-a:text-primary
      prose-img:rounded-2xl
      prose-pre:bg-neutral-900"
    >
      <slot />
    </article>
  </main>

  <footer class="border-t border-border bg-muted/40">
    <section class="max-w-5xl mx-auto px-6 py-15">
      <h2 class="text-3xl font-bold mb-10 tracking-tight text-foreground">
        {lang === "en" ? "Related articles" : "Artículos relacionados"}
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        <slot name="related" />
      </div>

      <div class="flex justify-center mt-12">
        <a
          href={blogHref}
          class="inline-flex items-center gap-2 px-8 py-3 rounded-full border border-border text-foreground font-semibold hover:bg-primary hover:text-primary-foreground hover:border-primary transition-all duration-300"
        >
          {viewAllText}
          <ArrowRight class="h-5 w-5" />
        </a>
      </div>
    </section>
  </footer>
</BaseLayout>
