---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
const { lang } = Astro.params;
const readingTime = Math.ceil(frontmatter.words / 200);
---

<BaseLayout
  title={`${frontmatter.title} | VelyonSoft`}
  description={frontmatter.description}
  image={frontmatter.cover}
  type="article"
  lang={lang}
>
  <header
    class="relative h-[60vh] min-h-[400px] flex items-end"
    id={frontmatter.cover ? "blog-hero" : undefined}
  >
    {
      frontmatter.cover && (
        <img
          src={frontmatter.cover}
          alt={frontmatter.title}
          class="absolute inset-0 w-full h-full object-cover"
        />
      )
    }
    <div
      class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"
    >
    </div>

    <div class="relative max-w-4xl mx-auto px-6 pb-16 w-full text-white">
      <h1
        class="text-4xl md:text-6xl font-extrabold tracking-tight leading-tight"
      >
        {frontmatter.title}
      </h1>
      <div class="flex flex-wrap gap-4 text-sm mt-6 text-white/80 items-center">
        <span class="bg-white/20 px-3 py-1 rounded-full backdrop-blur-md">
          {
            new Date(frontmatter.date).toLocaleDateString("es-PE", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })
          }
        </span>
        <span>•</span>
        <span class="font-medium text-white">{frontmatter.author}</span>
        <span>•</span>
        <span>{readingTime} min lectura</span>
      </div>
    </div>
  </header>

  <main class="bg-white">
    <article
      class="max-w-3xl mx-auto px-6 py-20
      prose prose-neutral prose-lg
      prose-headings:font-bold
      prose-a:text-primary
      prose-img:rounded-2xl
      prose-pre:bg-neutral-900"
    >
      <slot />
    </article>
  </main>

  <footer
    class="border-t border-neutral-100 bg-neutral-50"
  >
    <section class="max-w-5xl mx-auto px-6 py-24">
      <h2
        class="text-3xl font-bold mb-10 tracking-tight text-neutral-900"
      >
        Artículos relacionados
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <slot name="related" />
      </div>
    </section>
  </footer>
</BaseLayout>
