---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Services from "../../components/Services.astro";
import ProyectosGrid from "../../components/ProyectosGrid.astro";
import Partners from "@/components/Partners.astro";
import TestimonialCarousel from "@/components/TestimonialCarousel";
import BlogGrid from "@/components/BlogGrid.astro";
import FAQ from "../../components/FAQ";
import ContactForm from "../../components/ContactForm.astro";

type Lang = "es" | "en";

export async function getStaticPaths() {
	return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: Lang };
---

<BaseLayout
	lang={lang}
	title={lang === "es"
		? "Desarrollo de software a medida en Perú para empresas | VelyonSoft"
		: "Custom software development in Peru for businesses | VelyonSoft"}
	description={lang === "es"
		? "Desarrollamos software a medida, sistemas web y automatizaciones para empresas en Perú. Soluciones escalables para optimizar procesos y vender más."
		: "We build custom software, web systems and automations for businesses in Peru. Scalable solutions to optimize operations and grow faster."}
>
	<Hero lang={lang} />
	<Services lang={lang} onlyFeatured />
	<ProyectosGrid lang={lang} />
	<Partners lang={lang} />
	<TestimonialCarousel client:load lang={lang} />
	<BlogGrid lang={lang} />
	<FAQ lang={lang} />
	<ContactForm lang={lang} />
</BaseLayout>
