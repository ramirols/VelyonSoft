---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Services from "../../components/Services.astro";
import ProyectosGrid from "../../components/ProyectosGrid.astro";
import Partners from "@/components/Partners.astro";
import TestimonialCarousel from "@/components/TestimonialCarousel";
import BlogGrid from "@/components/BlogGrid.astro";
import FAQ from "../../components/FAQ";
import ContactForm from "../../components/ContactForm.astro";

type Lang = "es" | "en";

export async function getStaticPaths() {
	return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: Lang };
---

<BaseLayout
	lang={lang}
	title={lang === "es"
		? "Desarrollo de Software, Páginas Web y SEO en Perú | VelyonSoft"
		: "Software, Web Development & SEO in Peru | VelyonSoft"}
	description={lang === "es"
		? "Desarrollo de software a medida, páginas web profesionales, aplicaciones móviles y SEO para empresas en Perú."
		: "Custom software development, professional websites, mobile apps and SEO for companies in Peru."}
>
	<Hero lang={lang} />
	<Services lang={lang} onlyFeatured />
	<ProyectosGrid lang={lang} />
	<Partners lang={lang} />
	<TestimonialCarousel client:load lang={lang} />
	<BlogGrid lang={lang} />
	<FAQ client:load lang={lang} />
	<ContactForm lang={lang} />
</BaseLayout>
