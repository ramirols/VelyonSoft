---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ArrowUpRight } from "lucide-astro";

type Lang = "es" | "en";

export async function getStaticPaths() {
    const projects = await getCollection("proyectos");
    const langs: Lang[] = ["es", "en"];

    return projects.flatMap((project) =>
        langs.map((lang) => ({
            params: {
                lang,
                slug: project.id,
            },
        })),
    );
}

const lang: Lang = Astro.params.lang === "en" ? "en" : "es";
const slug = Astro.params.slug;

if (!slug) {
    throw new Error("Missing project slug");
}

const allProjects = await getCollection("proyectos");
const project = allProjects.find((p) => p.id === slug) as
    | CollectionEntry<"proyectos">
    | undefined;

if (!project) {
    throw new Error(`Project not found: ${slug}`);
}

const { Content } = await render(project);

const projectsHref = lang === "en" ? "/en/projects" : "/es/proyectos";
const projectsLabel = lang === "en" ? "Projects" : "Proyectos";
const ctaLabel = lang === "en" ? "Visit website" : "Visitar sitio";
---

<BaseLayout
    lang={lang}
    title={`${project.data.title} | ${lang === "es" ? "Proyectos" : "Projects"}`}
    description={project.data.description}
    image={project.data.cover}
    type="article"
>
    <article class="max-w-4xl mx-auto mt-[130px] px-6 flex flex-col gap-5">
        <nav class="mb-4">
            <div class="flex items-center gap-2 text-muted-foreground text-sm">
                <a
                    href={projectsHref}
                    class="flex items-center gap-1 hover:text-primary transition-colors font-medium"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                    {projectsLabel}
                </a>
                <span class="text-border">/</span>
                <span class="truncate text-muted-foreground"
                    >{project.data.title}</span
                >
            </div>
        </nav>

        {
            project.data.cover && (
                <img
                    src={project.data.cover}
                    alt={project.data.title}
                    loading="eager"
                    decoding="async"
                    class="w-full rounded-2xl shadow-sm"
                />
            )
        }

        <header>
            <h1 class="text-3xl md:text-4xl font-bold leading-tight">
                {project.data.title}
            </h1>

            <p class="text-muted-foreground text-lg mt-4 max-w-2xl">
                {project.data.description}
            </p>
        </header>

        <div class="prose prose-neutral dark:prose-invert prose-lg max-w-none">
            <Content />
        </div>

        {
            project.data.url && (
                <div class="mb-16">
                    <a
                        href={project.data.url}
                        data-external-link
                        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-primary-foreground font-semibold hover:bg-primary/90 transition"
                    >
                        {ctaLabel}
                        <ArrowUpRight class="w-5 h-5" />
                    </a>
                </div>
            )
        }
    </article>
</BaseLayout>

<script is:inline>
    const isTouch = window.matchMedia("(pointer: coarse)").matches;
    const links = document.querySelectorAll("[data-external-link]");

    links.forEach((link) => {
        if (!isTouch) {
            link.setAttribute("target", "_blank");
            link.setAttribute("rel", "noopener noreferrer");
        }
    });
</script>
