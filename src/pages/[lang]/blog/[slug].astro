---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BlogLayout from "../../../layouts/BlogLayout.astro";

type Lang = "es" | "en";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    const langs: Lang[] = ["es", "en"];

    return posts.flatMap((post) =>
        langs.map((lang) => ({
            params: {
                lang,
                slug: post.id,
            },
        })),
    );
}

const lang: Lang = Astro.params.lang === "en" ? "en" : "es";
const slug = Astro.params.slug;

if (!slug) {
    throw new Error("Missing blog slug");
}

const allPosts = await getCollection("blog");
const post = allPosts.find((p) => p.id === slug) as
    | CollectionEntry<"blog">
    | undefined;

if (!post) {
    throw new Error(`Blog post not found: ${slug}`);
}

const { Content } = await render(post);
const related = allPosts.filter((p) => p.id !== post.id).slice(0, 3);
---

<BlogLayout frontmatter={post.data}>
    <div class="prose prose-neutral prose-lg max-w-none">
        <Content />
    </div>

    {
        related.map((r) => (
            <a
                slot="related"
                href={`/${lang}/blog/${r.id}`}
                class="group block border border-border bg-card rounded-2xl overflow-hidden hover:shadow-lg transition"
            >
                {r.data.cover && (
                    <img
                        src={r.data.cover}
                        alt={r.data.title}
                        loading="lazy"
                        decoding="async"
                        class="h-40 w-full object-cover group-hover:scale-105 transition"
                    />
                )}

                <div class="p-5">
                    <h3 class="font-semibold text-lg leading-snug">
                        {r.data.title}
                    </h3>
                    <p class="text-sm text-muted-foreground mt-2">
                        {r.data.description}
                    </p>
                </div>
            </a>
        ))
    }
</BlogLayout>
