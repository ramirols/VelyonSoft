---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

type Lang = "es" | "en";

export async function getStaticPaths() {
    return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: Lang };

const posts = await getCollection("blog");

/* i18n */
const i18n: Record<Lang, any> = {
    es: {
        title: "Blog sobre desarrollo web, SEO y negocios (2025)",
        seoTitle: "Blog de desarrollo web, SEO y negocios (2025) | VelyonSoft",
        readMore: "Leer artículo",
    },
    en: {
        title: "Web Development, SEO & Business Blog (2025)",
        seoTitle: "Web Development, SEO & Business Blog (2025) | VelyonSoft",
        readMore: "Read post",
    },
};

const t = i18n[lang];
---

<BaseLayout title={t.seoTitle} lang={lang}>
    <section class="max-w-6xl mx-auto px-6 py-16 mt-[50px]">
        <h1
            class="text-4xl md:text-5xl font-extrabold text-primary mb-12 tracking-tight"
        >
            {t.title}
        </h1>

        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {
                posts.map((post) => (
                    <a
                        href={`/${lang}/blog/${post.id}`}
                        class="group flex flex-col h-full border border-border rounded-2xl bg-card overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-2"
                    >
                        {post.data.cover && (
                            <div class="relative aspect-[16/9] overflow-hidden">
                                <img
                                    src={post.data.cover}
                                    alt={post.data.title}
                                    loading="lazy"
                                    decoding="async"
                                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />

                                <div class="absolute top-4 left-4">
                                    <span class="bg-background/90 backdrop-blur-md text-primary text-[10px] uppercase tracking-widest font-bold px-3 py-1 rounded-full shadow-sm">
                                        {post.data.date.toLocaleDateString(
                                            lang === "es" ? "es-PE" : "en-US",
                                            { month: "short", day: "numeric" },
                                        )}
                                    </span>
                                </div>
                            </div>
                        )}

                        <div class="flex flex-col flex-1 p-6">
                            <h2 class="text-xl font-bold text-primary mb-3 group-hover:text-secondary transition-colors leading-snug">
                                {post.data.title}
                            </h2>

                            <p class="text-muted-foreground text-sm line-clamp-3 mb-6 flex-1">
                                {post.data.description}
                            </p>

                            <div class="flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-wider">
                                <span>{t.readMore}</span>
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="3"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="transition-transform group-hover:translate-x-1"
                                >
                                    <>
                                        <path d="M5 12h14" />
                                        <path d="m12 5 7 7-7 7" />
                                    </>
                                </svg>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </section>
</BaseLayout>
